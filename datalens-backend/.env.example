# ===========================================
# DataLens Backend Configuration
# Copy this file to .env and fill in values
# ===========================================

# Server
PORT=8080
ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://datalens:datalens@localhost:5432/datalens?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# MinIO / S3 Storage
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=datalens
S3_USE_SSL=false
S3_REGION=us-east-1

# AI Integration (optional - AI features disabled if not set)
# Providers: openai, anthropic (OpenAI-compatible)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096
# For OpenRouter, DeepSeek, Groq: set custom base URL
# AI_BASE_URL=https://openrouter.ai/api/v1

# Cron Scheduler
CRON_ENABLED=true
CRON_TIMEZONE=Asia/Jakarta

# External DB Connection Encryption (AES-256 - must be 32 chars)
DB_CONN_ENCRYPTION_KEY=CHANGE_ME_TO_EXACTLY_32_CHARS_KEY

# Database Connection Pool
DB_MAX_CONNECTIONS=50
DB_MAX_IDLE=10
