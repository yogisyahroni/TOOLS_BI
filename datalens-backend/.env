# ===========================================
# DataLens Backend - Production Environment
# ===========================================

# Server
PORT=8080
ENV=development

# Database (PostgreSQL) - provided by user
DATABASE_URL=postgresql://postgres:1234@localhost:5432/datalens

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=D9Bo+6ne-%mzYZ@#rwpbqgNfGt=R4X312lW78kF5!KiAuMdh
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# CORS - Frontend runs on separate origin (adjust for production)
# Development: Vite default port 5173
# Production: set to your frontend domain e.g. https://app.datalens.io
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# MinIO / S3 Storage (local dev - start with docker-compose)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=datalens
S3_USE_SSL=false
S3_REGION=us-east-1

# AI Integration (optional - AI features return 501 if not set)
# Compatible with: OpenAI, Groq, DeepSeek, OpenRouter, Anthropic (via OpenAI-compatible API)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096
# For custom providers (Groq, DeepSeek, OpenRouter):
# AI_BASE_URL=https://api.groq.com/openai/v1

# Cron Scheduler
CRON_ENABLED=true
CRON_TIMEZONE=Asia/Jakarta

# External DB Connection Encryption (AES-256 - must be exactly 32 chars)
DB_CONN_ENCRYPTION_KEY=*wx!NOKs^MAv5C%BYeUg32uHrfqGylpTXktb0=oV8FcW+Sa$

# Database Connection Pool
DB_MAX_CONNECTIONS=50
DB_MAX_IDLE=10

# Supabase Remote Database
SUPABASE_DB_URL=postgresql://postgres:Namakamu766!!@db.brxldmujfsnoygcufkmp.supabase.co:5432/postgres
