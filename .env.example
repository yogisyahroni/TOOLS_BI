# Neuradash Environment Variables Example
# Copy this file to .env and fill in your actual credentials

# --- API & Backend ---
# The base URL for the Go Fiber backend API
VITE_API_URL=https://your-backend-api.com/api/v1

# The WebSocket URL for real-time analytics and alerts
VITE_WS_URL=wss://your-backend-api.com/ws

# --- Supabase Configuration (If Applicable) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Feature Flags ---
# Set to 'true' to enable experimental AI features
VITE_ENABLE_AI_FEATURES=false

# --- Development Settings ---
# Set to 'debug' for more verbose logging in the console
VITE_LOG_LEVEL=info
