{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neuradash",
  "version": "0.1.9",
  "identifier": "com.neuradash.sentinel",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Neuradash Sentinel",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; connect-src 'self' wss://* https://* https://datalens-backend-8eph.onrender.com; style-src 'self' 'unsafe-inline' tauri:; script-src 'self' 'unsafe-inline' tauri:; img-src 'self' data: tauri: https://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "window-state": {},
    "fs": {},
    "notification": {},
    "shell": {},
    "dialog": {},
    "process": {},
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCQjNDQzQ2QTYxQTBERDkKUldUWkRScW1Sc3l6dTJMNjRiVFhwaFR5bWNyZ1JvUEZwK3cvZWNnbE5EL3l2S2h5b28zL1lkYWEK",
      "endpoints": [
        "https://github.com/yogisyahroni/TOOLS_BI/releases/latest/download/latest.json"
      ]
    }
  }
}