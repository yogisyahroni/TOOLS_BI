{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neuradash",
  "version": "0.1.1",
  "identifier": "com.neuradash.sentinel",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Neuradash Sentinel",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: http://localhost:5173; connect-src 'self' ws://localhost:5173 wss://* https://* http://localhost:*; style-src 'self' 'unsafe-inline' tauri:; script-src 'self' 'unsafe-inline' tauri: http://localhost:5173; img-src 'self' data: tauri: http://localhost:5173 https://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "window-state": {},
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1MkQ3MUU2NDQwQ0ZBMDUKUldRRitneEU1bkV0TmFSS1hqVEhBR044RnloWUVBZENGTktwUDAyOU8zNnN5VkRBeUVXclIyWFMK",
      "endpoints": [
        "https://github.com/yogisyahroni/TOOLS_BI/releases/latest/download/latest.json"
      ]
    }
  }
}
